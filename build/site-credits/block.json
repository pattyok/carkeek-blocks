{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "carkeek-blocks/site-credits",
  "version": "0.1.0",
  "title": "Site Credits",
  "category": "widgets",
  "description": "Place Site Credits and Copyright information.",
  "supports": {
    "html": true,
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontStyle": true,
      "fontWeight": true,
      "textDecoration": true,
      "textTransform": true
    }
  },
  "textdomain": "carkeek-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "attributes": {
    "showCredits": {
      "type": "boolean",
      "default": true
    },
    "showCopyright": {
      "type": "boolean",
      "default": true
    },
    "contentAfter": {
      "type": "string",
      "default": ""
    },
    "creditsLinkLabel": {
      "type": "string",
      "default": "Site Credits"
    },
    "creditsPopupContent": {
      "type": "string",
      "default": ""
    }
  }
}